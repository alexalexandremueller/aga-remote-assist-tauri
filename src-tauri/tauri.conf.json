{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AGA Remote Assist",
  "version": "0.1.0",
  "identifier": "br.com.hsistemas.aga-remote-assist",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:4174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AGA Remote Assist",
        "width": 1220,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
